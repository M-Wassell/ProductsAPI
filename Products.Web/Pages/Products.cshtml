
@page
@model Products.Web.Pages.ProductsModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h1>Products</h1>

<table class="table">
    <thead>
        <tr>
            <th>
                Name
            </th>
            <th>
                Price
            </th>
            <th>
                Category
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.Price</td>
                <td>@product.Category</td>
                <td>
                    <a asp-page="/Shared/Details" asp-route-id="@product.Id" 
                    class="btn btn-info">View Details</a>
                </td>
            </tr>

            
        }
    </tbody>
</table>

