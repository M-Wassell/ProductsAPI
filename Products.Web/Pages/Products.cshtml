
@page
@model Products.Web.Pages.ProductsModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div class="page-container">
    <h1 class="page-title">Products</h1>

    <table class="table products-table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Price</th>
                <th>Description</th>
                <th>Stock Quantity</th>
                <th>Category</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model.Products)
            {
                <tr data-product-id="@product.Id">
                    <td>@product.Id</td>
                    <td data-field="name">@product.Name</td>
                    <td data-field="price">@product.Price</td>
                    <td data-field="description">@product.Description</td>
                    <td data-field="stockQuantity">@product.StockQuantity</td>
                    <td data-field="category">@product.Category</td>
                    <td>
                        <button class="btn btn-sm btn-primary view-btn"
                                data-product-id="@product.Id">
                            View
                        </button>
                        <button class="btn btn-sm btn-primary edit-btn"
                                data-product-id="@product.Id">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-danger delete-btn"
                                data-product-id="@product.Id">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="productModalTitle"></h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p><strong>Price:</strong> £<span id="modalProductPrice"></span></p>
                <hr />
                <p><strong>Description</strong></p>
                <p id="modalProductDescription"></p>
            </div>

        </div>
    </div>
</div>


<div class="modal fade" id="editProductModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Edit Product</h5>
                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="editProductId" />

                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" id="editProductName" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Price</label>
                    <input type="number" class="form-control" id="editProductPrice" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" id="editProductDescription"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Stock Quantity</label>
                    <input type="number" id="editProductStock" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Category</label>
                    <select class="form-select" id="editProductCategory">
                        <option value="Sport">Sport</option>
                        <option value="Electronics">Electronics</option>
                        <option value="Optical">Optical</option>
                        <option value="Home">Home</option>
                        <option value="Beer">Beer</option>
                    </select>
                </div>

                <button type="button"
                        id="saveProductBtn"
                        class="btn btn-primary">
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

<section class="create-product">
    <h2>Create Product</h2>

    <form id="createProductForm">
        <div class="mb-2">
            <label>Name</label>
            <input class="form-control" id="createName" />
        </div>

        <div class="mb-2">
            <label>Price</label>
            <input type="number" class="form-control" id="createPrice" />
        </div>

        <div class="mb-2">
            <label>Description</label>
            <textarea class="form-control" id="createDescription"></textarea>
        </div>

        <div class="mb-2">
            <label>Stock Quantity</label>
            <input type="number" class="form-control" id="createStock" />
        </div>

        <div class="mb-2">
            <label>Category</label>
            <select class="form-select" id="createCategory">
                <option value="Sport">Sport</option>
                <option value="Electronics">Electronics</option>
                <option value="Optical">Optical</option>
                <option value="Home">Home</option>
                <option value="Beer">Beer</option>
            </select>
        </div>

        <button type="button"
                id="createProductBtn"
                class="btn btn-success">
            Create Product
        </button>

    </form>

    <div id="createErrors" class="text-danger mt-2"></div>
    <div id="successDiv" class="text-success mt-2"></div>

</section>



@section Styles {
    <link rel="stylesheet" href="~/css/products.css" />
}

@section Scripts {
    <script src="~/js/products.js"></script>
}
